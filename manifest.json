{
  "manifest_version": 3,
  "name": "Price Anchor Remover",
  "version": "1.0",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*", "*://*.amazon.sg/*"],
      "js": ["content.js"]
    }
  ]
}